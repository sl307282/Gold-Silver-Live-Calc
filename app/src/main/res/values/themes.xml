<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.GoldSilverLiveCalc" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m" xmlns:tools="http://schemas.android.com/tools">false</item>
    </style>

    <!-- Theme for Splash Screen API (Android 12+) -->
    <style name="Theme.GoldSilverLiveCalc.Splash" parent="Theme.SplashScreen">
        <!-- Set the splash screen background to dark #0D0E15 (matching Compose background theme) -->
        <item name="windowSplashScreenBackground">#0D0E15</item>
        <!-- Use custom sized splash icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <!-- The theme to transition to after the splash screen finishes -->
        <item name="postSplashScreenTheme">@style/Theme.GoldSilverLiveCalc</item>
    </style>
</resources>
